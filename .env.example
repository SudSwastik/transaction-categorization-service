# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=txcat
VERSION=0.1.0
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://txcat:txcat_dev@postgres:5432/txcat

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redis_dev@redis:6379/0

# ── Auth0 ─────────────────────────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.txcat.io
AUTH0_JWKS_CACHE_TTL_SECONDS=43200

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
LLM_MAX_RETRIES=3
LLM_RATE_LIMIT_PER_MINUTE=10

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── File Storage ──────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_ROOT=/app/uploads
MAX_UPLOAD_SIZE_BYTES=52428800

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── Categorization Pipeline ───────────────────────────────────────────────────
STAGE1_CONFIDENCE_THRESHOLD=0.95
STAGE2_CONFIDENCE_THRESHOLD=0.85
STAGE2_MIN_MATCH_COUNT=5
STAGE3_CONFIDENCE_THRESHOLD=0.92
CATEGORIZATION_BATCH_SIZE=20

# ── Analytics ─────────────────────────────────────────────────────────────────
ANALYTICS_CACHE_TTL_SECONDS=1800

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

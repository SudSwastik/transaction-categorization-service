# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=txcat
VERSION=0.1.0
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://txcat:txcat_dev@postgres:5432/txcat

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redis_dev@redis:6379/0

# ── Auth0 ─────────────────────────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.txcat.io
AUTH0_JWKS_CACHE_TTL_SECONDS=43200

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
LLM_MAX_RETRIES=3
LLM_RATE_LIMIT_PER_MINUTE=10

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── File Storage (MinIO) ──────────────────────────────────────────────────────
# For real AWS S3: set AWS_ENDPOINT_URL="" and update credentials below
STORAGE_BACKEND=s3
AWS_ENDPOINT_URL=http://minio:9000
AWS_BUCKET=txcat-uploads
AWS_ACCESS_KEY_ID=txcat
AWS_SECRET_ACCESS_KEY=txcat_dev_minio
AWS_REGION=us-east-1
MAX_UPLOAD_SIZE_BYTES=52428800

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── Categorization Pipeline ───────────────────────────────────────────────────
STAGE1_CONFIDENCE_THRESHOLD=0.95
STAGE2_CONFIDENCE_THRESHOLD=0.85
STAGE2_MIN_MATCH_COUNT=5
STAGE3_CONFIDENCE_THRESHOLD=0.92
CATEGORIZATION_BATCH_SIZE=20

# ── Currencies ────────────────────────────────────────────────────────────────
# Base currency for amount_base conversion on transactions (per-tenant override stored in DB)
DEFAULT_BASE_CURRENCY=INR
SUPPORTED_CURRENCIES=["INR","USD","EUR","GBP","CAD","AUD"]

# ── Analytics ─────────────────────────────────────────────────────────────────
ANALYTICS_CACHE_TTL_SECONDS=1800

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]
